# ==========================================
# Quick3DQuote — environment variables
# Copy to .env.local for dev. Never commit .env files.
# ==========================================

# ---- Public URLs (dashboard apex + widget subdomain) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EMBED_URL=http://localhost:3001

# ---- Supabase ----
# Dashboard client uses anon key + user JWT; server-only code uses service role.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never expose

# ---- Stripe (platform account — we bill shops £50/mo) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...   # £50/mo
STRIPE_PRICE_ID_PRO=price_...       # £99/mo
STRIPE_PRICE_ID_SCALE=price_...     # £199/mo

# ---- Stripe Connect (OAuth for shop-owned accounts — for customer checkout) ----
# Direct-to-shop payments. Each shop connects their own Stripe via OAuth.
STRIPE_CLIENT_ID=ca_...

# ---- Cloudflare R2 (mesh file storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_MESHES=quick3dquote-meshes-dev
R2_PUBLIC_BASE_URL=https://meshes-dev.quick3dquote.com

# ---- Quote engine (FastAPI service on Fly.io) ----
QUOTE_ENGINE_URL=http://localhost:8000
QUOTE_ENGINE_INTERNAL_KEY=change-me-to-a-long-random-string

# ---- Observability (optional in dev) ----
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---- Rate limiting (Upstash Redis) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
